# frozen_string_literal: true

# Official source — kept canonical so GitHub Actions (overseas) resolves fast.
# For local installs in China, redirect to a mirror once with:
#   bundle config set mirror.https://rubygems.org https://mirrors.tuna.tsinghua.edu.cn/rubygems/
source "https://rubygems.org"

# Jekyll and the plugins this site relies on.
gem "jekyll", "~> 4.4"
gem "jekyll-paginate", "~> 1.1"   # blog pagination
gem "jemoji", "~> 0.13"           # GitHub-style emoji in content
gem "jekyll-spaceship", "~> 0.10" # renders ```mermaid code blocks into diagrams

# webrick is no longer bundled with Ruby 3+, needed for `jekyll serve`
gem "webrick", "~> 1.8"
