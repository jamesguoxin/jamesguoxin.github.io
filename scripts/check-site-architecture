#!/usr/bin/env ruby
# frozen_string_literal: true

require_relative "site-check-helpers"

ROOT = SiteCheckHelpers::ROOT

home = SiteCheckHelpers.page("index.html")
publications = SiteCheckHelpers.page("publications/index.html")
news = SiteCheckHelpers.page("news/index.html")
activities = SiteCheckHelpers.page("activities/index.html")
posts = [
  SiteCheckHelpers.page("tech/2026/04/05/foundation-models-meet-biology.html"),
  SiteCheckHelpers.page("tech/2023/03/19/chatgpt.html"),
  SiteCheckHelpers.page("cuisine/2016/04/04/res-rec.html")
]

robots_path = File.join(ROOT, "_site", "robots.txt")
abort("Generated site must include robots.txt") unless File.exist?(robots_path)
robots = File.read(robots_path)
abort("robots.txt must allow crawlers") unless robots.include?("User-agent: *") && robots.include?("Allow: /")
abort("robots.txt must declare sitemap") unless robots.include?("Sitemap: https://jamesguoxin.github.io/sitemap.xml")

expected_home_sections = %w[about research publications news experience contact]
home_main = home.at_css("body > main")
abort("Homepage sections must be wrapped in a main landmark") unless home_main

actual_home_sections = home.css("body > main > section[id]").map { |node| node["id"] }
unless actual_home_sections == expected_home_sections
  abort("Homepage sections expected #{expected_home_sections.inspect}, got #{actual_home_sections.inspect}")
end

abort("Homepage must show 4 news entries") unless home.css("#news .news-item").length == 4
abort("Homepage must show 6 publications") unless home.css("#publications .publication-item").length == 6
abort("SkySense missing from homepage") unless home.at_css("#publications").text.include?("SkySense")

hero_focus = home.css(".hero-focus span").map { |node| SiteCheckHelpers.normalized_text(node) }
expected_hero_focus = [
  "AI for Life Sciences · Multimodal Scientific Foundation Models",
  "Scientific Agentic AI · Automated Labs for Discovery"
]
unless hero_focus == expected_hero_focus
  abort("Hero focus expected #{expected_hero_focus.inspect}, got #{hero_focus.inspect}")
end

about_text = home.at_css("#about").text.gsub(/\s+/, " ").strip
[
  "AI for life sciences",
  "scientific discovery",
  "multi-omics",
  "biological representation learning",
  "FLAG",
  "ChromFound",
  "SOLD"
].each do |phrase|
  abort("About section missing #{phrase.inspect}") unless about_text.include?(phrase)
end
abort("About section should not position HorusEye as a core work") if about_text.include?("HorusEye")
abort("About metric must show 20+ papers") unless home.at_css("#about .metric-card strong", text: "20+")

expected_research_titles = [
  "AI for Life Sciences",
  "Multimodal Scientific Foundation Models",
  "Scientific Agentic AI",
  "Automated Labs for Closed-Loop Discovery"
]
actual_research_titles = home.css("#research .research-card h3").map { |node| SiteCheckHelpers.normalized_text(node) }
unless actual_research_titles == expected_research_titles
  abort("Research highlight titles expected #{expected_research_titles.inspect}, got #{actual_research_titles.inspect}")
end

contact_text = home.at_css("#contact").text.gsub(/\s+/, " ").strip
[
  "multi-omics",
  "spatial biology",
  "RNA design",
  "scientific foundation models",
  "tool-using AI systems",
  "automated labs",
  "closed-loop discovery"
].each do |phrase|
  abort("Contact section missing collaboration phrase #{phrase.inspect}") unless contact_text.include?(phrase)
end

config = YAML.load_file(File.join(ROOT, "_config.yml"))
expected_contact_emails = ["guoxin@sais.org.cn", "tigerguoxin@gmail.com"]
unless config["emails"] == expected_contact_emails
  abort("Contact emails expected #{expected_contact_emails.inspect}")
end
expected_contact_emails.each do |email|
  user, domain = email.split("@", 2)
  unless home.to_html.include?(user) && home.to_html.include?(domain)
    abort("Contact section must render obfuscated email parts for #{email}")
  end
end

expected_section_actions = {
  "#publications" => ["View all publications →", SiteCheckHelpers.internal_path("/publications/")],
  "#news" => ["More news →", SiteCheckHelpers.internal_path("/news/")],
  "#experience" => ["Academic & Professional Activities →", SiteCheckHelpers.internal_path("/activities/")]
}
expected_section_actions.each do |selector, (label, href)|
  action = home.at_css("#{selector} .section-heading-row .section-heading-action")
  abort("Missing section action for #{selector}") unless action
  unless SiteCheckHelpers.normalized_text(action) == label && action["href"] == href
    abort("Section action mismatch for #{selector}")
  end
  abort("Section action for #{selector} must not remain at the section bottom") if home.at_css("#{selector} .section-more")
end

expected_titles = [
  "FLAG: Foundation model representation with Latent diffusion Alignment via Graph for spatial gene expression prediction",
  "HorusEye: a self-supervised foundation model for generalizable X-ray tomography restoration",
  "Structure-based RNA Design by Step-wise Optimization of Latent Diffusion Model",
  "Sprint or Delve: A Distribution-Aware Approach to Efficient Reasoning",
  "ChromFound: Towards A Universal Foundation Model for Single-Cell Chromatin Accessibility Data",
  "SkySense: A Multi-Modal Remote Sensing Foundation Model Towards Universal Interpretation for Earth Observation Imagery"
]
actual_titles = home.css("#publications .publication-title").map { |node| node.text.gsub(/\s+/, " ").strip }
abort("Selected publication order mismatch") unless actual_titles == expected_titles

expected_selected_code_links = {
  "FLAG: Foundation model representation with Latent diffusion Alignment via Graph for spatial gene expression prediction" => "https://github.com/SAIS-LifeScience/FLAG",
  "HorusEye: a self-supervised foundation model for generalizable X-ray tomography restoration" => "https://github.com/Arturia-Pendragon-Iris/HorusEye_XRT_Restoration",
  "Structure-based RNA Design by Step-wise Optimization of Latent Diffusion Model" => "https://github.com/SAIS-LifeScience/SOLD",
  "ChromFound: Towards A Universal Foundation Model for Single-Cell Chromatin Accessibility Data" => "https://github.com/SAIS-LifeScience/ChromFound",
  "SkySense: A Multi-Modal Remote Sensing Foundation Model Towards Universal Interpretation for Earth Observation Imagery" => "https://github.com/Jack-bo1220/SkySense"
}
selected_items = home.css("#publications .publication-item")
selected_items.each do |item|
  title = item.at_css(".publication-title").text.gsub(/\s+/, " ").strip
  paper_links = item.css(".publication-resource-link").select { |node| SiteCheckHelpers.normalized_text(node) == "Paper" }

  expected_code_href = expected_selected_code_links[title]
  code_links = item.css(".publication-resource-link").select { |node| SiteCheckHelpers.normalized_text(node) == "Code" }
  if expected_code_href
    abort("Selected publication #{title.inspect} missing Paper resource link") if paper_links.empty?
    abort("Selected publication #{title.inspect} missing Code resource link") if code_links.empty?
    unless code_links.any? { |node| node["href"] == expected_code_href }
      abort("Selected publication #{title.inspect} Code link mismatch")
    end
  elsif title.start_with?("Sprint or Delve")
    abort("Sprint or Delve must not show a placeholder Paper link") unless paper_links.empty?
    abort("Sprint or Delve must not show a placeholder Code link") unless code_links.empty?
  end
end

publication_data = YAML.load_file(File.join(ROOT, "_data", "publications.yml"))
expected_publications = publication_data.sum { |group| group.fetch("papers").length }
abort("Source publication count expected 19, got #{expected_publications}") unless expected_publications == 19
unless publications.css(".publication-item").length == expected_publications
  abort("Complete publication count mismatch")
end
poa_item = publications.css(".publication-item").find do |item|
  item.text.include?("POA: Pre-training Once for Models of All Sizes")
end
abort("Complete publications missing POA") unless poa_item
poa_code = poa_item.css(".publication-resource-link").find do |node|
  SiteCheckHelpers.normalized_text(node) == "Code"
end
unless poa_code && poa_code["href"] == "https://github.com/alipay/POA/tree/main"
  abort("POA must include official Code link")
end
expected_complete_code_links = {
  "Structure-aware Semantic Discrepancy and Consistency for 3D Medical Image Self-supervised Learning" => "https://github.com/Ashespt/S2DC",
  "Towards a Universal 3D Medical Multi-modality Generalization via Learning Personalized Invariant Representation" => "https://github.com/zhaorui-tan/PUIR_ICCV25",
  "SCRIPT: Predicting Single-Cell Long-Range Cis-Regulation Based on Pretrained Graph Attention Networks" => "https://github.com/SAIS-LifeScience/SCRIPT"
}
expected_complete_code_links.each do |title, expected_href|
  item = publications.css(".publication-item").find { |node| node.text.include?(title) }
  abort("Complete publications missing #{title}") unless item

  code_link = item.css(".publication-resource-link").find do |node|
    SiteCheckHelpers.normalized_text(node) == "Code"
  end
  unless code_link && code_link["href"] == expected_href
    abort("#{title} must include official Code link")
  end
end

news_data = YAML.load_file(File.join(ROOT, "_data", "news.yml"))
abort("Source news count expected 7, got #{news_data.length}") unless news_data.length == 7
abort("Complete news count mismatch") unless news.css(".news-item").length == news_data.length

abort("Activities page lost patents") unless activities.text.include?("EP3201917B1")
abort("Activities page lost awards") unless activities.text.include?("ICML 2026 Silver Reviewer Award")
activities_title = activities.at_css(".standalone-page h1")
expected_activities_title = "Academic & Professional Activities"
unless SiteCheckHelpers.normalized_text(activities_title) == expected_activities_title
  abort("Activities title expected #{expected_activities_title.inspect}")
end
abort("Activities page must not include the obsolete CV prompt") if activities.text.include?("Please contact me for CV.")

expected_activity_counts = {
  "Selected Patents" => 10,
  "Academic Services" => 2,
  "Interviews" => 2,
  "Competitions" => 4
}
activity_headings = activities.css(".standalone-page h3")
expected_activity_counts.each do |heading, expected_count|
  heading_node = activity_headings.find { |node| SiteCheckHelpers.normalized_text(node) == heading }
  abort("Activities page missing #{heading} heading") unless heading_node

  list = heading_node.xpath("following-sibling::*[1][self::ol]").first
  actual_count = list ? list.element_children.count { |node| node.name == "li" } : 0
  unless actual_count == expected_count
    abort("Activities #{heading} count expected #{expected_count}, got #{actual_count}")
  end
end

awards_heading = activity_headings.find do |node|
  SiteCheckHelpers.normalized_text(node) == "Honors & Awards"
end
abort("Activities page missing Honors & Awards heading") unless awards_heading
awards = awards_heading.xpath("following-sibling::p[not(contains(concat(' ', normalize-space(@class), ' '), ' cv-note '))]")
award_count = awards.length
abort("Activities awards count expected 12, got #{award_count}") unless award_count == 12
award_texts = awards.map { |node| SiteCheckHelpers.normalized_text(node) }
abort("Activities awards must be newest first") unless award_texts.first.start_with?("2026:")
abort("Activities awards must keep oldest entries last") unless award_texts.last.start_with?("2008:")
abort("Activities page must explain Dingsunbao Chinese branding") unless activities.text.include?("Dingsunbao (定损宝")
abort("Activities page must clarify Shanghai Oriental Talent Program") unless activities.text.include?("Shanghai municipal young-talent program")

future_work = File.read(File.join(ROOT, "future-work.md"))
abort("Future work must not mention stale 15+ paper metric") if future_work.include?("15+ papers")
abort("Future work must include publication metadata audit") unless future_work.include?("Publication Metadata Audit")
abort("Future work must track unknown code links") unless future_work.include?("No official code currently listed")

expected_author_blurb = "Xin Guo is a Principal Research Scientist at the Shanghai AI Laboratory, focusing on AI for life sciences, multimodal scientific foundation models, scientific agentic AI, and automated labs for closed-loop discovery. His work aims to build AI systems that connect biological data, scientific reasoning, and experimental discovery. He has studied and worked in Switzerland, Germany, and the UK. Outside research, he enjoys coffee, Swiss chocolate, badminton, and basketball."
unless config["author_blurb"] == expected_author_blurb
  abort("Author blurb must use the updated academic profile copy")
end
abort("Author blurb must not mention Stephen Curry") if config["author_blurb"].include?("Stephen Curry")

workflow = File.read(File.join(ROOT, ".github", "workflows", "jekyll.yml"))
{
  "actions/checkout@v5" => "Checkout must use the Node 24 runtime action",
  "actions/configure-pages@v6" => "Configure Pages must use the Node 24 runtime action",
  "actions/upload-pages-artifact@v5" => "Upload Pages artifact must use the Node 24 runtime action",
  "actions/deploy-pages@v5" => "Deploy Pages must use the Node 24 runtime action"
}.each do |expected_action, message|
  abort(message) unless workflow.include?(expected_action)
end
abort("Pages deploy workflow must grant actions: read permission") unless workflow.include?("actions: read")

scss_files = Dir.glob(File.join(ROOT, "{css,_sass}", "**", "*.scss"))
scss_files.each do |path|
  relative_path = path.delete_prefix("#{ROOT}/")
  abort("#{relative_path} must use Sass modules instead of @import") if File.read(path).match?(/^\s*@import\b/)
end
readme = File.read(File.join(ROOT, "README.md"))
abort("README must not describe Sass @import warnings as expected") if readme.include?("Sass `@import` deprecation warnings")

posts.each do |post|
  canonical = post.at_css("link[rel='canonical']")
  abort("Post canonical must be absolute") unless canonical && canonical["href"].start_with?("https://jamesguoxin.github.io/")

  meta_description = post.at_css("meta[name='description']")
  abort("Post must have a page-specific meta description") unless meta_description
  if meta_description["content"] == config["description"] || meta_description["content"].length < 80
    abort("Post meta description must be page-specific and substantial")
  end

  {
    "og:title" => "Post must include Open Graph title",
    "og:description" => "Post must include Open Graph description",
    "og:url" => "Post must include Open Graph URL",
    "og:type" => "Post must include Open Graph type"
  }.each do |property, message|
    abort(message) unless post.at_css("meta[property='#{property}']")
  end

  og_url = post.at_css("meta[property='og:url']")["content"]
  abort("Post Open Graph URL must be absolute") unless og_url.start_with?("https://jamesguoxin.github.io/")
  abort("Post Open Graph type must be article") unless post.at_css("meta[property='og:type']")["content"] == "article"
end

expected_nav = ["About", "Research", "Experience", "Contact", "Blog ↗"]
actual_nav = home.css(".navbar-main-collapse .nav > li > a").map { |node| node.text.strip }
abort("Primary navigation mismatch") unless actual_nav == expected_nav

abort("Homepage navbar must remain hero-transparent") if home.at_css("nav.navbar-standalone")
[publications, news, activities].each do |page|
  abort("Standalone page navbar missing persistent contrast class") unless page.at_css("nav.navbar-standalone")
end

expected_home_nav_hrefs = [
  "#about",
  "#research",
  "#experience",
  "#contact",
  SiteCheckHelpers.internal_path("/blog/")
]
actual_home_nav_hrefs = home.css(".navbar-main-collapse .nav > li > a").map { |node| node["href"] }
unless actual_home_nav_hrefs == expected_home_nav_hrefs
  abort("Homepage nav hrefs expected #{expected_home_nav_hrefs.inspect}, got #{actual_home_nav_hrefs.inspect}")
end

expected_news_nav_hrefs = [
  SiteCheckHelpers.internal_path("/#about"),
  SiteCheckHelpers.internal_path("/#research"),
  SiteCheckHelpers.internal_path("/#experience"),
  SiteCheckHelpers.internal_path("/#contact"),
  SiteCheckHelpers.internal_path("/blog/")
]
actual_news_nav_hrefs = news.css(".navbar-main-collapse .nav > li > a").map { |node| node["href"] }
unless actual_news_nav_hrefs == expected_news_nav_hrefs
  abort("News nav hrefs expected #{expected_news_nav_hrefs.inspect}, got #{actual_news_nav_hrefs.inspect}")
end

[home, publications, news, activities].each do |page|
  activities_href = SiteCheckHelpers.internal_path("/activities/")
  abort("Footer must not link to Activities") if page.at_css("footer a[href='#{activities_href}']")
end

generated_pages = Dir.glob(File.join(ROOT, "_site", "**", "*.html"))
generated_pages.each do |path|
  html = File.read(path)
  relative_path = path.delete_prefix("#{File.join(ROOT, "_site")}/")
  if html.match?(/disqus|#disqus_thread|disqus_thread|>\s*Comments\s*</i)
    abort("Generated page #{relative_path} must not include Disqus or comment UI")
  end
end

puts "Site architecture checks passed"
